# Configurações de Ambiente - Registro de Usuários com Recompensa
# Copie este arquivo para .env e substitua os valores conforme necessário

# ===========================================
# CONFIGURAÇÕES DA REDE
# ===========================================

# Rede de destino (sepolia, localhost, etc.)
NETWORK=sepolia

# URL do RPC (opcional - use public RPC se não tiver)
RPC_URL=https://sepolia.infura.io/v3/YOUR_INFURA_PROJECT_ID

# Chain ID da Sepolia Testnet
CHAIN_ID=11155111

# ===========================================
# ENDEREÇO DO CONTRATO
# ===========================================

# Substitua pelo endereço do seu contrato após o deploy
CONTRACT_ADDRESS=0x0000000000000000000000000000000000000000

# ===========================================
# CONFIGURAÇÕES DA APLICAÇÃO
# ===========================================

# Nome da aplicação
APP_NAME=Registro de Usuários com Recompensa

# Versão da aplicação
APP_VERSION=1.0.0

# Ambiente (development, staging, production)
NODE_ENV=development

# ===========================================
# CHAVE PRIVADA (APENAS PARA DESENVOLVIMENTO)
# ===========================================

# ⚠️ ATENÇÃO: Use apenas para desenvolvimento local!
# Para deploy em produção, use MetaMask diretamente
# NUNCA compartilhe sua chave privada ou envie para repositórios!
PRIVATE_KEY=your_private_key_here

# ===========================================
# CONFIGURAÇÕES DO SERVIDOR WEB
# ===========================================

# Porta do servidor web
PORT=8000

# Host do servidor
HOST=localhost

# ===========================================
# CONFIGURAÇÕES DE LOG
# ===========================================

# Nível de log (debug, info, warn, error)
LOG_LEVEL=info

# Diretório de logs
LOG_DIR=logs

# ===========================================
# CONFIGURAÇÕES DE TESTE
# ===========================================

# Endereço de teste para deploy local
TEST_CONTRACT_ADDRESS=0x5FbDB2315678afecb367f032d93F642f64180aa3

# Conta de teste (para Hardhat local)
TEST_ACCOUNT=0xf39Fd6e51aad88F6F4ce6aB8827279cffFb92266

# ===========================================
# INSTRUÇÕES DE USO
# ===========================================

# 1. Copie este arquivo para .env:
#    cp .env.example .env
#
# 2. Substitua CONTRACT_ADDRESS pelo endereço real do seu contrato
#
# 3. Se for usar scripts de deploy local, substitua PRIVATE_KEY
#
# 4. Ajuste outras configurações conforme necessário
#
# 5. NUNCA commit o arquivo .env para o repositório!
#
# 6. Para deploy via Remix/MetaMask, apenas CONTRACT_ADDRESS é necessário
